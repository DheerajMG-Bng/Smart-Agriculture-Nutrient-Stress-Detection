    "# Create nutrient stress labels based on thresholds\n",
    "\n",
    "def stress_label(row):\n",
    "    \n",
    "    if row[\"N\"] < 50 or row[\"P\"] < 30 or row[\"K\"] < 30:\n",
    "        return \"Deficient\"\n",
    "    \n",
    "    elif row[\"pH\"] < 5.5 or row[\"pH\"] > 8:\n",
    "        return \"Stress\"\n",
    "    \n",
    "    else:\n",
    "        return \"Normal\"\n",
    "\n",
    "data[\"Stress\"] = data.apply(stress_label, axis=1)\n",
